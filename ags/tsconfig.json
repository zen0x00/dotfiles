{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "jsxImportSource": "astal/gtk4",
    "moduleResolution": "bundler",
    "strict": false,
    "baseUrl": ".",
    "paths": {
      "astal/gtk4": ["/usr/share/astal/gjs/gtk4/index.ts"],
      "astal/gtk4/*": ["/usr/share/astal/gjs/gtk4/*.ts"],
      "astal": ["/usr/share/astal/gjs/index.ts"],
      "astal/*": ["/usr/share/astal/gjs/*.ts"]
    }
  }
}
