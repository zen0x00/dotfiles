#!/usr/bin/env python3
"""Merges matugen-generated VSCode colors into settings.json without touching other settings."""

import json
import re
import sys

SETTINGS = "/home/aman/.config/Code/User/settings.json"
COLORS = "/tmp/matugen-vscode-colors.json"


def strip_comments(text):
    # Remove /* ... */ block comments
    text = re.sub(r'/\*.*?\*/', '', text, flags=re.DOTALL)
    # Remove // line comments (not inside strings)
    text = re.sub(r'//[^\n]*', '', text)
    # Remove trailing commas before } or ]
    text = re.sub(r',\s*([\]}])', r'\1', text)
    return text


with open(SETTINGS, "r") as f:
    raw = f.read()

with open(COLORS, "r") as f:
    colors = json.load(f)

settings = json.loads(strip_comments(raw))
settings["material-code.colors"] = colors

with open(SETTINGS, "w") as f:
    json.dump(settings, f, indent=2)
    f.write("\n")
