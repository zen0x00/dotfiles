#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "$0")")/.." && pwd)"

[[ $# -eq 1 ]] || { echo "Usage: theme <wallpaper-image>" >&2; exit 1; }
[[ -f "$1" ]] || { echo "File not found: $1" >&2; exit 1; }

WALLPAPER="$(realpath "$1")"

# Set wallpaper
if command -v awww >/dev/null 2>&1; then
    awww img "$WALLPAPER" --transition-type grow --transition-duration 1 2>/dev/null || true
fi

# Render all configs and run post_hooks (kitty SIGUSR1, hyprctl reload)
matugen image "$WALLPAPER" --prefer less-saturation --mode dark

# Apply GTK dark mode via gsettings (authoritative on Wayland, overrides settings.ini)
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
gsettings set org.gnome.desktop.interface gtk-theme '' 2>/dev/null || true


# Restart Quickshell with new Colors.qml
if command -v quickshell >/dev/null 2>&1; then
    quickshell kill -p "$ROOT/quickshell" 2>/dev/null || true
    nohup quickshell -p "$ROOT/quickshell" >/tmp/quickshell.log 2>&1 &
fi

echo "Theme applied from: $WALLPAPER"
