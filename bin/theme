#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "$0")")/.." && pwd)"

[[ $# -eq 1 ]] || { echo "Usage: theme <wallpaper-image>" >&2; exit 1; }
[[ -f "$1" ]] || { echo "File not found: $1" >&2; exit 1; }

WALLPAPER="$(realpath "$1")"

# Set wallpaper
if command -v awww >/dev/null 2>&1; then
    awww img "$WALLPAPER" --transition-type grow --transition-duration 1 2>/dev/null || true
fi

# Render all configs and run post_hooks (kitty SIGUSR1, hyprctl reload)
matugen image "$WALLPAPER" --prefer less-saturation --mode dark

# Merge VSCode colors into settings.json
VSCODE_SETTINGS="$HOME/.config/Code/User/settings.json"
VSCODE_COLORS="$HOME/.config/Code/User/matugen-colors.json"
if [[ -f "$VSCODE_COLORS" && -f "$VSCODE_SETTINGS" ]]; then
    python3 - <<'PYEOF'
import re, json, os
settings_path = os.path.expanduser('~/.config/Code/User/settings.json')
colors_path   = os.path.expanduser('~/.config/Code/User/matugen-colors.json')

with open(settings_path) as f:
    raw = f.read()

raw = re.sub(r'//[^\n]*', '', raw)
raw = re.sub(r'/\*.*?\*/', '', raw, flags=re.DOTALL)
raw = re.sub(r',(\s*[}\]])', r'\1', raw)

settings = json.loads(raw)
with open(colors_path) as f:
    colors = json.load(f)

settings.update(colors)
with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)
PYEOF
fi

# Restart Quickshell with new Colors.qml
if command -v quickshell >/dev/null 2>&1; then
    quickshell kill -p "$ROOT/quickshell" 2>/dev/null || true
    nohup quickshell -p "$ROOT/quickshell" >/tmp/quickshell.log 2>&1 &
fi

echo "Theme applied from: $WALLPAPER"
