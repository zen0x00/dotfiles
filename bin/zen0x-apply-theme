#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "$0")")/.." && pwd)"

if [ "$#" -ne 1 ]; then
    echo "Usage: zen0x-apply-theme <theme>" >&2
    echo "Available themes:" >&2
    find "$ROOT/themes" -mindepth 2 -maxdepth 2 -name colors.toml -printf '  %h\n' | sed "s|$ROOT/themes/||" | sort >&2
    exit 2
fi

"$ROOT/bin/zen0x-generate-theme" "$1"
"$ROOT/bin/zen0x-theme-reload"
