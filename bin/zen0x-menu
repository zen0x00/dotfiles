#!/bin/bash

MAIN=$(printf "Wallpaper\nFont\nMode" | zen0x-launch-walker -d -p "Zen Menu" --width 200 --maxheight 250 --minheight 250)
[ -z "$MAIN" ] && exit

case "$MAIN" in

  Wallpaper)
    WALLDIR="$(dirname "$(readlink -f "$0")")/../walls"

    CHOICE=$(find -L "$WALLDIR" -type f \( \
      -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.png" -o -iname "*.webp" \
    \) -printf "%f\n" | sort | zen0x-launch-walker -d -p "Wallpaper")

    [ -z "$CHOICE" ] && exit

    FILE=$(find -L "$WALLDIR" -type f -iname "$CHOICE" -print -quit)
    [ -z "$FILE" ] && exit

    awww img "$FILE" \
      --transition-type grow \
      --transition-duration 2 \
      --transition-fps 60

    ln -sf "$FILE" "$HOME/.current_wallpaper"

    # Generate colors from wallpaper and reload apps
    matugen image "$FILE" --prefer=saturation
    pkill -SIGUSR2 waybar 2>/dev/null
    hyprctl reload
    ;;

  Font)
    FONT=$(fc-list --format="%{family[0]}\n" | sort -u | zen0x-launch-walker -d -p "Font")
    [ -z "$FONT" ] && exit

    CONFIG="$HOME/.config"

    # Kitty
    sed -i "s|^font_family.*|font_family      family=\"$FONT\"|" "$CONFIG/kitty/kitty.conf"

    # Walker
    sed -i "s|font-family:.*|font-family: $FONT;|" "$CONFIG/walker/themes/current/style.css"

    # Wlogout
    sed -i "s|font-family:.*|font-family: $FONT;|" "$CONFIG/wlogout/style.css"

    # SwayOSD
    sed -i "s|font-family:.*|font-family: '$FONT';|" "$CONFIG/swayosd/style.css"

    # GTK 3
    mkdir -p "$CONFIG/gtk-3.0"
    if [ -f "$CONFIG/gtk-3.0/settings.ini" ]; then
      sed -i "s|^gtk-font-name=.*|gtk-font-name=$FONT 11|" "$CONFIG/gtk-3.0/settings.ini"
    else
      printf "[Settings]\ngtk-font-name=$FONT 11\n" > "$CONFIG/gtk-3.0/settings.ini"
    fi

    # Reload waybar
    pkill -SIGUSR2 waybar 2>/dev/null

    # Reload kitty
    pkill -SIGUSR1 kitty 2>/dev/null
    ;;

  Mode)
    MODES_DIR="$HOME/.config/modes"
    MODE=$(ls -1 "$MODES_DIR" | sort | zen0x-launch-walker -d -p "Mode")
    [ -z "$MODE" ] && exit
    zen0x-mode "$MODE"
    ;;

esac
