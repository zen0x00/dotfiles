#!/bin/bash

MAIN=$(printf "Wallpaper\nFont\nMode" | rofi -dmenu -p "Zen Menu" -theme-str 'window { width: 200px; }')
[ -z "$MAIN" ] && exit

case "$MAIN" in

  Wallpaper)
    qs ipc call wallpicker toggle
    ;;

  Font)
    FONT=$(fc-list --format="%{family[0]}\n" | sort -u | rofi -dmenu -p "Font")
    [ -z "$FONT" ] && exit

    CONFIG="$HOME/.config"

    # Kitty
    sed -i "s|^font_family.*|font_family      family=\"$FONT\"|" "$CONFIG/kitty/kitty.conf"

    # Rofi
    sed -i "s|font:.*|font: \"$FONT 12\";|" "$CONFIG/rofi/themes/minimal.rasi"
    sed -i "s|font:.*|font: \"$FONT 12\";|" "$CONFIG/rofi/themes/eye-candy.rasi"

    # Wlogout
    sed -i "s|font-family:.*|font-family: $FONT;|" "$CONFIG/wlogout/style.css"

    # SwayOSD
    sed -i "s|font-family:.*|font-family: '$FONT';|" "$CONFIG/swayosd/style.css"

    # GTK 3
    mkdir -p "$CONFIG/gtk-3.0"
    if [ -f "$CONFIG/gtk-3.0/settings.ini" ]; then
      sed -i "s|^gtk-font-name=.*|gtk-font-name=$FONT 11|" "$CONFIG/gtk-3.0/settings.ini"
    else
      printf "[Settings]\ngtk-font-name=$FONT 11\n" > "$CONFIG/gtk-3.0/settings.ini"
    fi

    # Reload waybar
    pkill -SIGUSR2 waybar 2>/dev/null

    # Reload kitty
    pkill -SIGUSR1 kitty 2>/dev/null
    ;;

  Mode)
    MODES_DIR="$HOME/.config/modes"
    MODE=$(ls -1 "$MODES_DIR" | sort | rofi -dmenu -p "Mode")
    [ -z "$MODE" ] && exit
    zen0x-mode "$MODE"
    ;;

esac
