#!/bin/bash

MAIN=$(printf "Theme\nWallpaper\nFont\nMode" | qs ipc call launcher dmenu 2>/dev/null)
[ -z "$MAIN" ] && exit

THEMES="$HOME/hyprdots/themes/colorschemes"
CURRENT="$HOME/.config/themes/current"

case "$MAIN" in

  Theme)
    THEME=$(ls -1 "$THEMES" | grep -v current | qs ipc call launcher dmenu 2>/dev/null)
    [ -z "$THEME" ] && exit

    ln -sfn "$THEMES/$THEME" "$CURRENT"

    zen0x-theme-generate "$THEME"
    zen0x-apply-generated-theme
    zen0x-theme-gtk
    zen0x-theme-set-vscode
    zen0x-theme-wallpaper "$THEME"
    zen0x-theme-reload
    ;;

  Wallpaper)
    qs ipc call wallpicker toggle
    ;;

  Font)
    FONT=$(fc-list --format="%{family[0]}\n" | sort -u | qs ipc call launcher dmenu 2>/dev/null)
    [ -z "$FONT" ] && exit

    CONFIG="$HOME/.config"

    sed -i "s|^font_family.*|font_family      family=\"$FONT\"|" "$CONFIG/kitty/kitty.conf"

    mkdir -p "$CONFIG/gtk-3.0"
    if [ -f "$CONFIG/gtk-3.0/settings.ini" ]; then
      sed -i "s|^gtk-font-name=.*|gtk-font-name=$FONT 11|" "$CONFIG/gtk-3.0/settings.ini"
    else
      printf "[Settings]\ngtk-font-name=$FONT 11\n" > "$CONFIG/gtk-3.0/settings.ini"
    fi

    pkill -SIGUSR1 kitty 2>/dev/null
    ;;

  Mode)
    MODES_DIR="$HOME/.config/modes"
    MODE=$(ls -1 "$MODES_DIR" | sort | qs ipc call launcher dmenu 2>/dev/null)
    [ -z "$MODE" ] && exit
    zen0x-mode "$MODE"
    ;;

esac
