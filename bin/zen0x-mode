#!/bin/bash

MODES_DIR="$HOME/.config/modes"
STATE_FILE="/tmp/zen0x_mode"

HYPR_CONFIGS="$HOME/.config/hypr/configs"
ROFI_THEMES="$HOME/.config/rofi/themes"

current_mode() {
    if [ -f "$STATE_FILE" ]; then
        cat "$STATE_FILE"
    else
        echo "minimal"
    fi
}

apply_mode() {
    local mode="$1"
    local mode_dir="$MODES_DIR/$mode"

    if [ ! -d "$mode_dir" ]; then
        echo "Mode not found: $mode"
        exit 1
    fi

    # Hyprland — copy general.conf and animations.conf (colors.conf stays untouched)
    cp "$mode_dir/hypr/general.conf" "$HYPR_CONFIGS/general.conf"
    cp "$mode_dir/hypr/animations.conf" "$HYPR_CONFIGS/animations.conf"
    hyprctl reload

    # Rofi — symlink the mode theme as current.rasi
    ln -sf "$ROFI_THEMES/$mode.rasi" "$ROFI_THEMES/current.rasi"

    # Quickshell — switch bar mode via IPC
    if [ "$mode" = "eye-candy" ]; then
        qs ipc call bar switchToIsland 2>/dev/null || true
    else
        qs ipc call bar switchToClassic 2>/dev/null || true
    fi
    qs ipc call shell reload 2>/dev/null || true

    echo "$mode" > "$STATE_FILE"
    notify-send "Mode" "$(echo "$mode" | sed 's/-/ /g; s/\b./\U&/g')"
}

# If a mode name is passed, apply it directly
if [ -n "$1" ]; then
    apply_mode "$1"
    exit 0
fi

# Otherwise, toggle
case "$(current_mode)" in
    minimal) apply_mode "eye-candy" ;;
    *) apply_mode "minimal" ;;
esac
