#!/usr/bin/env bash
set -u

status=0

if command -v hyprctl >/dev/null 2>&1; then
    if ! hyprctl reload; then
        echo "Warning: Hyprland reload failed." >&2
        status=1
    fi
else
    echo "Warning: hyprctl not found; skipped Hyprland reload." >&2
    status=1
fi

if command -v pkill >/dev/null 2>&1; then
    pkill -SIGUSR1 kitty 2>/dev/null || true
fi

# Reload AGS CSS (bar picks up new colors.css)
command -v astal >/dev/null 2>&1 && astal -i zen0x reload-css 2>/dev/null || true

command -v swaync-client >/dev/null 2>&1 && swaync-client --reload-css 2>/dev/null || true

command -v gsettings >/dev/null 2>&1 && gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true

ROOT="$(cd -- "$(dirname -- "$(readlink -f -- "$0")")/.." && pwd)"
command -v jq >/dev/null 2>&1 && "$ROOT/bin/zen0x-theme-set-vscode" 2>/dev/null || true

if [[ -f "$ROOT/.current-theme" ]]; then
    wallpaper="$ROOT/themes/$(cat "$ROOT/.current-theme")/wallpaper.jpg"
    if [[ -f $wallpaper ]]; then
        ln -sf "$wallpaper" "$HOME/.config/hypr/wallpaper.jpg"
        command -v awww >/dev/null 2>&1 && awww img "$wallpaper" --transition-type any --transition-fps 60 2>/dev/null || true
    fi
fi

command -v pkill >/dev/null 2>&1 && pkill -HUP hyprlock 2>/dev/null || true

for _sock in /run/user/$(id -u)/nvim.*.0; do
    [[ -S "$_sock" ]] && nvim --server "$_sock" --remote-send ':colorscheme zen0x<CR>' 2>/dev/null || true
done
unset _sock

if [ "$status" -eq 0 ]; then
    notify-send "zen0x" "Reloaded: Hyprland, Kitty, AGS, SwayNC, VSCode, Nvim."
else
    notify-send -u critical "zen0x" "Theme files generated, but one or more reload steps failed."
fi

exit "$status"
