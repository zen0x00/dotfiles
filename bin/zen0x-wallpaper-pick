#!/usr/bin/env python3
"""Rofi wallpaper picker with thumbnail previews."""

import hashlib
import os
import subprocess
import sys
from pathlib import Path

WALLDIR = Path(__file__).resolve().parent.parent / "walls"
THUMB_DIR = Path.home() / ".cache/thumbnails/large"
THUMB_DIR.mkdir(parents=True, exist_ok=True)

EXTENSIONS = {".jpg", ".jpeg", ".png", ".webp"}


def thumb_path(filepath: Path) -> Path:
    uri = f"file://{filepath}"
    md5 = hashlib.md5(uri.encode()).hexdigest()
    return THUMB_DIR / f"{md5}.png"


def ensure_thumb(filepath: Path) -> Path:
    thumb = thumb_path(filepath)
    if not thumb.exists():
        subprocess.run(
            ["magick", str(filepath), "-thumbnail", "256x256^", "-gravity", "center",
             "-extent", "256x256", str(thumb)],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    return thumb


def main():
    walls = sorted(
        p for p in WALLDIR.iterdir()
        if p.suffix.lower() in EXTENSIONS
    )

    # Build rofi input: "name\0icon\x1f/path/to/thumb\n"
    entries = []
    for wall in walls:
        thumb = ensure_thumb(wall)
        icon = str(thumb) if thumb.exists() else ""
        entries.append(f"{wall.name}\0icon\x1f{icon}")

    rofi_input = "\n".join(entries)

    result = subprocess.run(
        ["rofi", "-dmenu", "-p", "Wallpaper", "-show-icons",
         "-theme", os.path.expanduser("~/.config/rofi/themes/wallpaper.rasi")],
        input=rofi_input, capture_output=True, text=True
    )

    choice = result.stdout.strip()
    if not choice:
        sys.exit(0)

    # Find the full path
    match = next((w for w in walls if w.name == choice), None)
    if not match:
        sys.exit(1)

    print(str(match))


if __name__ == "__main__":
    main()
