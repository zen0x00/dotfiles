{
  "include": [
  "$HOME/.config/waybar/Modules"
  ],
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 4,
  "height": 30,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [],
  "modules-right": [
    "tray",
    "pulseaudio",
    "cpu",
    "memory",
    "disk",
    "clock"
  ]
}
