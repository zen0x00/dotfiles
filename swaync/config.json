{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "top",
  "cssPriority": "user",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "control-center-width": 360,
  "control-center-height": 680,
  "notification-window-width": 360,
  "fit-to-screen": false,
  "relative-timestamps": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "keyboard-shortcuts": true,
  "widgets": [
    "buttons-grid",
    "volume",
    "dnd",
    "title",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "󰃢"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },
    "buttons-grid": {
      "buttons-per-row": 5,
      "actions": [
        {
          "label": "󰝟",
          "command": "/home/aman/dotfiles/bin/zen0x-toggle-mute"
        },
        {
          "label": "󰤨",
          "command": "/home/aman/dotfiles/bin/zen0x-toggle-wifi"
        },
        {
          "label": "󰂯",
          "command": "/home/aman/dotfiles/bin/zen0x-toggle-bluetooth"
        },
        {
          "label": "󰖔",
          "command": ""
        },
        {
          "label": "󰀝",
          "command": ""
        }
      ]
    }
  }
}
