{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "top",
  "cssPriority": "user",
  "control-center-margin-top": 8,
  "control-center-margin-bottom": 8,
  "control-center-margin-right": 8,
  "control-center-margin-left": 0,
  "control-center-width": 400,
  "control-center-height": 680,
  "notification-window-width": 360,
  "fit-to-screen": false,
  "relative-timestamps": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "keyboard-shortcuts": true,
  "widgets": [
    "title",
    "dnd",
    "volume",
    "backlight",
    "buttons-grid",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Control Center",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "volume": {
      "label": "󰕾",
      "show-per-app": false
    },
    "backlight": {
      "label": "󰃟"
    },
    "mpris": {
      "image-size": 56,
      "image-radius": 12
    },
    "buttons-grid": {
      "buttons-per-row": 2,
      "actions": [
        {
          "label": "󰤨\nWi-Fi",
          "command": "/home/aman/dotfiles/bin/zen0x-toggle-wifi"
        },
        {
          "label": "󰂯\nBluetooth",
          "command": "/home/aman/dotfiles/bin/zen0x-toggle-bluetooth"
        },
        {
          "label": "󰝟\nMute",
          "command": "/home/aman/dotfiles/bin/zen0x-toggle-mute"
        },
        {
          "label": "󰂚\nDo Not Disturb",
          "command": "swaync-client -d"
        }
      ]
    }
  }
}
