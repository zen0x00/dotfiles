{
  "workbench.colorCustomizations": {
    "editor.selectionBackground": "{{ colors.primary.default.hex }}44",
    "editor.inactiveSelectionBackground": "{{ colors.primary.default.hex }}22",
    "editor.selectionHighlightBackground": "{{ colors.primary.default.hex }}22",
    "editorCursor.foreground": "{{ colors.primary.default.hex }}",
    "editorLineNumber.foreground": "{{ colors.on_surface_variant.default.hex }}55",
    "editorLineNumber.activeForeground": "{{ colors.primary.default.hex }}",
    "editor.findMatchBackground": "{{ colors.primary.default.hex }}44",
    "editor.findMatchHighlightBackground": "{{ colors.primary.default.hex }}22",
    "editorError.foreground": "{{ colors.error.default.hex }}",
    "editorWarning.foreground": "{{ colors.secondary.default.hex }}",
    "editorInfo.foreground": "{{ colors.primary.default.hex }}",
    "terminal.foreground": "{{ colors.on_background.default.hex }}",
    "terminalCursor.foreground": "{{ colors.primary.default.hex }}",
    "terminal.selectionBackground": "{{ colors.primary.default.hex }}44"
  },
  "material-code.colors": {
    "primary": "{{ colors.primary.default.hex }}",
    "foreground": "{{ colors.on_background.default.hex }}",
    "mutedForeground": "{{ colors.on_surface_variant.default.hex }}",
    "background": "{{ colors.background.default.hex }}",
    "card": "{{ colors.surface_container.default.hex }}",
    "popover": "{{ colors.surface_container_high.default.hex }}",
    "hover": "{{ colors.surface_container_highest.default.hex }}",
    "border": "{{ colors.outline_variant.default.hex }}",
    "primaryForeground": "{{ colors.on_primary.default.hex }}",
    "secondary": "{{ colors.secondary.default.hex }}",
    "secondaryForeground": "{{ colors.on_secondary.default.hex }}",
    "error": "{{ colors.error.default.hex }}",
    "errorForeground": "{{ colors.on_error.default.hex }}",
    "success": "{{ colors.tertiary.default.hex }}",
    "warning": "{{ colors.secondary.default.hex }}",
    "syntax.comment": "{{ colors.on_surface_variant.default.hex }}",
    "syntax.string": "{{ colors.tertiary.default.hex }}",
    "syntax.keyword": "{{ colors.primary.default.hex }}",
    "syntax.variable": "{{ colors.on_background.default.hex }}",
    "syntax.attribute": "{{ colors.secondary.default.hex }}",
    "syntax.property": "{{ colors.on_tertiary_container.default.hex }}",
    "syntax.function": "{{ colors.on_primary_container.default.hex }}",
    "syntax.constant": "{{ colors.on_surface_variant.default.hex }}",
    "syntax.bracket1": "{{ colors.primary.default.hex }}",
    "syntax.bracket2": "{{ colors.secondary.default.hex }}",
    "syntax.bracket3": "{{ colors.tertiary.default.hex }}",
    "syntax.bracket4": "{{ colors.error.default.hex }}"
  }
}
