{
  "include": [
  "$HOME/.config/waybar/Modules"
  ],
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "spacing": 10,
  "height": 32,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "tray",
    "custom/separator#dot",
    "cpu",
    "memory",
    "disk",
    "clock"
  ]
}
